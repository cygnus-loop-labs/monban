{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "monban",
    "version": "0.1.0",
    "identifier": "labs.cygnus-loop.monban",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "windows": [
            {
                "title": "門番",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": false
    }
}
